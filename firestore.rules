rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY DEFINITIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'himanshu712007@gmail.com' ||
        request.auth.uid == 'DjQkzY4U4Tb5xLmOyywopbVC8453' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isRider() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/riders/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('role', 'Customer') == 'Rider')
      );
    }

    function riderIdMatchesAuth(riderIdVal) {
      return riderIdVal != null && (
        riderIdVal == request.auth.uid ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('riderId', '') == riderIdVal)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- VALIDATION BLUEPRINTS ---

    function isValidUserProfile(data) {
      return data.userId is string && data.userId.size() <= 128
          && data.name is string && data.name.size() <= 200
          && data.email is string && data.email.size() <= 200
          && data.phone is string && data.phone.size() <= 50
          && data.role is string && (data.role == 'Customer' || data.role == 'Rider' || data.role == 'Admin');
    }

    function isValidOrder(data) {
      return data.id is string && data.id.size() <= 128
          && data.userId is string && data.userId.size() <= 128
          && data.total is number && data.total >= 0
          && data.status is string && (
            data.status == 'placed' ||
            data.status == 'confirmed' ||
            data.status == 'packed' ||
            data.status == 'out_for_delivery' ||
            data.status == 'delivered' ||
            data.status == 'cancelled'
          );
    }

    function isValidRider(data) {
      return data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 200
          && data.phone is string && data.phone.size() <= 50
          && data.email is string && data.email.size() <= 200
          && data.vehicleNumber is string && data.vehicleNumber.size() <= 100;
    }

    function isValidReview(data) {
      return data.id is string && data.id.size() <= 128
          && data.productId is string && data.productId.size() <= 128
          && data.userId is string && data.userId.size() <= 128
          && data.userName is string && data.userName.size() <= 200
          && data.rating is number && data.rating >= 1 && data.rating <= 5
          && data.comment is string && data.comment.size() <= 5000
          && data.createdAt is string && data.createdAt.size() <= 100
          && data.orderId is string && data.orderId.size() <= 128;
    }

    function isValidProduct(data) {
      return data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 300
          && data.category is string && data.category.size() <= 100
          && data.sellingPrice is number && data.sellingPrice >= 0
          && data.stock is number && data.stock >= 0;
    }

    function isValidCombo(data) {
      return data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 300
          && data.originalPrice is number && data.originalPrice >= 0
          && data.comboPrice is number && data.comboPrice >= 0
          && data.savings is number
          && data.products is list;
    }

    // --- COLLECTION RULES MATCHERS ---

    // 1. User profile collection
    match /profiles/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // 2. Orders collection
    match /orders/{orderId} {
      allow read: if isAdmin()
        || (resource.data.userId == request.auth.uid)
        || (isRider() && (
             resource.data.status == 'placed' || 
             riderIdMatchesAuth(resource.data.rider_id) || 
             resource.data.rider_id == null || 
             resource.data.rider_id == 'rider-unassigned'
           ));
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin()
        || (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid)
        || (isRider() && (
             resource.data.status == 'placed' || 
             riderIdMatchesAuth(resource.data.rider_id) || 
             riderIdMatchesAuth(request.resource.data.rider_id) ||
             resource.data.rider_id == null ||
             resource.data.rider_id == 'rider-unassigned'
           ));
      allow delete: if isAdmin();
    }
    
    // 3. Admin list definitions
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // 4. Riders register list
    match /riders/{riderId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && riderIdMatchesAuth(riderId));
      allow delete: if isAdmin();
    }

    // 5. Users private addresses and subcollections
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'himanshu712007@gmail.com');
      
      match /addresses/{addressId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'himanshu712007@gmail.com');
      }
    }

    // 6. Product Reviews collection
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && reviewId == request.auth.uid + "_" + request.resource.data.productId
        && isValidReview(request.resource.data)
        && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.userId == request.auth.uid
        && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.status == 'delivered';
      allow update: if isSignedIn() 
        && resource.data.userId == request.auth.uid 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.productId == resource.data.productId
        && request.resource.data.orderId == resource.data.orderId
        && isValidReview(request.resource.data);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // 7. Products collection
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if (isAdmin() || (
        isSignedIn() && 
        isValidProduct(request.resource.data) &&
        request.resource.data.name == resource.data.name &&
        request.resource.data.sellingPrice == resource.data.sellingPrice &&
        request.resource.data.get('price', 0) == resource.data.get('price', 0) &&
        request.resource.data.id == resource.data.id
      ));
      allow delete: if isAdmin();
    }

    // 8. Combo deals collection
    match /combos/{comboId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCombo(request.resource.data);
      allow delete: if isAdmin();
    }

    // 9. Global Settings collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
